# GateTrack Sentinel Phase 4.4 settings
GTS_ENV=development
GTS_API_HOST=127.0.0.1
GTS_API_PORT=8000
GTS_DB_PATH=runtime/gatetrack_sentinel.db

# Use "adk" for the real ADK + MCP + Gemini path.
# Use "mock" for a fully offline deterministic demonstration.
GTS_MODEL_MODE=adk
GTS_MODEL=gemini-2.5-flash
GTS_MODEL_TIMEOUT_SECONDS=18
GTS_MODEL_MAX_ATTEMPTS=2
GTS_MCP_CONNECT_TIMEOUT_SECONDS=12
GTS_MCP_REUSE_ENABLED=true
GTS_MCP_PREWARM_ENABLED=true
GTS_MODEL_THINKING_BUDGET=0
GTS_AGENT_CIRCUIT_BREAKER_SECONDS=90
GTS_MODEL_FALLBACK_ENABLED=true
GTS_AGENT_EVALUATION_CASES=5
GTS_ADK_APP_NAME=gatetrack_sentinel_api
GTS_ADK_USER_ID=gatetrack_demo_user
GTS_LOG_LEVEL=INFO

# Keep the key only in .env. Never commit it.
# Either variable is supported; GOOGLE_API_KEY takes precedence if both are set.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Frontend (copy to frontend/.env.local only when the API is hosted elsewhere)
VITE_API_BASE=http://127.0.0.1:8000
